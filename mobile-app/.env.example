# AIAdvocate Environment Variables
# Copy this file to .env and fill in your actual values

# Sentry DSN for error tracking
# Get this from https://sentry.io after creating a project
# Format: https://[key]@[host]/[project-id]
EXPO_PUBLIC_SENTRY_DSN=

# Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL=https://klpwiiszmzzfvlbfsjrd.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Optional public client configuration
EXPO_PUBLIC_LNF_URL=
EXPO_PUBLIC_RECAPTCHA_SITE_KEY=
EXPO_PUBLIC_FIREBASE_WEB_CONFIG=

# Do not add LocationIQ/OpenStates keys here.
# Expo EXPO_PUBLIC_* values are bundled into client apps.
